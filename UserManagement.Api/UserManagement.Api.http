@HostAddress = http://localhost:5067

# 1. Login to retrieve the JWT token
# Fill the token in the `@token` variable below to authenticate subsequent requests.
# @name login
POST {{HostAddress}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "bilal.ahmed@example.com",
  "password": "Password123!"
}

###

# Copy the value of $.data.token from the login response and paste it below:
@token =eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..JguJ2rIh17ZdFeFZ2e9DA7WTHJYXt-OFpWAu7gm3Vk4
###

# 2. Get Users (Paginated, Searchable, Sortable)
# Try changing query parameters: pageNumber, pageSize, searchTerm, orderBy
GET {{HostAddress}}/api/v1/users?pageNumber=1&pageSize=10&searchTerm=Bilal&orderBy=lastName desc
Authorization: Bearer {{token}}

###

# 3. Get User By ID
GET {{HostAddress}}/api/v1/users/1022
Authorization: Bearer {{token}}

###

# 4. Create a New User
POST {{HostAddress}}/api/v1/users
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "firstName": "Ismail",
  "lastName": "Malik",
  "email": "zia.fyp26+new@hazelsoft.org"
}

###

# 5. Update an Existing User (Note: Email property is no longer editable)
PUT {{HostAddress}}/api/v1/users/1022
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "firstName": "Bilal",
  "lastName": "Ahmed Updated"
}

###

# 6. Delete a User
DELETE {{HostAddress}}/api/v1/users/1025
Authorization: Bearer {{token}}

###

# 7. Dynamic Filtering Tests (Success Cases)

# 7.1 Filter by exact email (string equality)
GET {{HostAddress}}/api/v1/users?filters=email==bilal.ahmed@example.com
Authorization: Bearer {{token}}

###

# 7.2 Filter by partial matching (case-insensitive contains)
GET {{HostAddress}}/api/v1/users?filters=firstName@=sar
Authorization: Bearer {{token}}

###

# 7.3 Filter by Boolean state
GET {{HostAddress}}/api/v1/users?filters=emailConfirmed==true
Authorization: Bearer {{token}}

###

# 7.4 Filter by Boolean state using binary integers (1/0)
GET {{HostAddress}}/api/v1/users?filters=emailConfirmed==1
Authorization: Bearer {{token}}

###

# 7.5 Filter by numeric comparison (greater than)
GET {{HostAddress}}/api/v1/users?filters=id>1023
Authorization: Bearer {{token}}

###

# 7.6 Filter by quoted string values
GET {{HostAddress}}/api/v1/users?filters=firstName=="Sarah"
Authorization: Bearer {{token}}

###

# 7.7 Combined Filters: Boolean Status AND Numeric ID
GET {{HostAddress}}/api/v1/users?filters=emailConfirmed==true,id>=1022
Authorization: Bearer {{token}}

###

# 7.8 Combined Filters with Search and OrderBy
GET {{HostAddress}}/api/v1/users?filters=emailConfirmed==true&searchTerm=khan&orderBy=firstName desc
Authorization: Bearer {{token}}

###

# 8. Dynamic Filtering Tests (Validation Failure Cases - Expected 400 Bad Request)

# 8.1 Wrong type format (Boolean parsing error)
GET {{HostAddress}}/api/v1/users?filters=emailConfirmed==not_a_boolean
Authorization: Bearer {{token}}

###

# 8.2 Wrong type format (Integer parsing error)
GET {{HostAddress}}/api/v1/users?filters=id==abc
Authorization: Bearer {{token}}

###

# 8.3 Non-existent property name
GET {{HostAddress}}/api/v1/users?filters=age==25
Authorization: Bearer {{token}}

###

# 8.4 Invalid operator syntax
GET {{HostAddress}}/api/v1/users?filters=emailEqualsvalue
Authorization: Bearer {{token}}

###

# 8.5 Multiple validation errors collected together
GET {{HostAddress}}/api/v1/users?filters=emailConfirmed==abc,invalidProperty==true
Authorization: Bearer {{token}}
